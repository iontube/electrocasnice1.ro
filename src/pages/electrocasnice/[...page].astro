---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import products from '../../data/electrocasnice.json';
import categories from '../../data/categories.json';

export function getStaticPaths({ paginate }) {
  const sorted = [...products].sort((a, b) => a.price - b.price);
  return paginate(sorted, { pageSize: 48 });
}
const { page } = Astro.props;
const money = (n) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const total = products.length;
const pageMod = page.data.reduce((m, p) => (p.modified && p.modified > m ? p.modified : m), '2026-04-01');
const catCounts = {}; for (const p of products) catCounts[p.category] = (catCounts[p.category] || 0) + 1;
const catList = categories.map((c) => ({ ...c, c: catCounts[c.slug] || 0 })).filter((c) => c.c > 0).sort((a, b) => b.c - a.c);
const brandList = Object.values(products.reduce((a, p) => { if (p.brandSlug) { (a[p.brandSlug] ||= { n: p.brand, s: p.brandSlug, c: 0 }).c++; } return a; }, {})).filter((b) => b.c >= 4).sort((a, b) => b.c - a.c).slice(0, 24);
const merchSet = {}; for (const p of products) for (const o of p.offers) (merchSet[o.merchantSlug] ||= { n: o.merchantName, s: o.merchantSlug, c: 0 }).c++;
const merchList = Object.values(merchSet).filter((m) => m.c >= 4).sort((a, b) => b.c - a.c);
const title = page.currentPage === 1 ? `Electrocasnice ieftine: ${total} oferte și prețuri ${new Date().getFullYear()} | Electrocasnice1.ro` : `Electrocasnice ieftine – pagina ${page.currentPage} | Electrocasnice1.ro`;
const desc = `Toate electrocasnicele din magazinele partenere: ${total} de produse — frigidere, mașini de spălat, aragaze, aspiratoare, aparate de cafea și multe altele, cu cele mai mici prețuri.${page.currentPage > 1 ? ` Pagina ${page.currentPage}.` : ''}`;
---
<Layout title={title} description={desc} modified={pageMod}>
  <Nav />
  <section class="rec-sec">
    <div class="wrap">
      <nav class="rec-bc"><a href="/">Acasă</a> › <span>Toate electrocasnicele</span></nav>
      <div class="sec-head">
        <span class="sec-head__tag">Catalog</span>
        <h1>Electrocasnice ieftine — {total} de oferte</h1>
        <p><strong>{total}</strong> de electrocasnice din magazinele partenere, cu cel mai mic preț pe fiecare model. Pagina {page.currentPage} din {page.lastPage}.</p>
      </div>

      <div class="rec-links" style="margin-top:0"><h2>Pe categorii</h2><div class="rec-links__row">{catList.map((c) => <a class="rec-pg" href={`/${c.slug}/`}>{c.label} <span>({c.c})</span></a>)}</div></div>

      <div class="products">
        {page.data.map((p) => (
          <article class="card">
            {p.oldPrice && <span class="card__badge card__badge--value">-{Math.round((1 - p.price / p.oldPrice) * 100)}%</span>}
            <a class="card__img" href={`/produs/${p.slug}/`} aria-label={p.name}><img src={p.img} alt={p.name} width="200" height="200" loading="lazy" decoding="async" /></a>
            <div class="card__body">
              <a href={`/produs/${p.slug}/`}><h3 class="card__name">{p.name}</h3></a>
              <div class="card__specs">{Object.values(p.specs).slice(1, 4).map((v) => <span class="card__spec">{v}</span>)}</div>
              <div class="card__price-row"><span class="card__price">{money(p.price)}</span>{p.oldPrice && <s>{money(p.oldPrice)}</s>}</div>
              <div class="card__foot"><a href={`/produs/${p.slug}/`} class="card__cta">Vezi detalii</a></div>
            </div>
          </article>
        ))}
      </div>

      <nav class="rec-pager" aria-label="Paginare">
        {page.url.prev ? <a class="rec-pg" href={page.url.prev}>← Anterioarele</a> : <span class="rec-pg rec-pg--off">← Anterioarele</span>}
        <span class="rec-pg-now">Pagina {page.currentPage} / {page.lastPage}</span>
        {page.url.next ? <a class="rec-pg" href={page.url.next}>Următoarele →</a> : <span class="rec-pg rec-pg--off">Următoarele →</span>}
      </nav>

      <div class="rec-links"><h2>După brand</h2><div class="rec-links__row">{brandList.map((b) => <a class="rec-pg" href={`/brand/${b.s}/`}>{b.n} <span>({b.c})</span></a>)}</div></div>
      <div class="rec-links"><h2>După magazin</h2><div class="rec-links__row">{merchList.map((m) => <a class="rec-pg" href={`/magazin/${m.s}/`}>{m.n} <span>({m.c})</span></a>)}</div></div>
    </div>
  </section>
  <Footer />
</Layout>
