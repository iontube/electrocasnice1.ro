---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  function slugify(text: string) {
    return text.toLowerCase()
      .replace(/[ăâ]/g, 'a').replace(/[îi]/g, 'i').replace(/[șş]/g, 's').replace(/[țţ]/g, 't')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  const allPages = import.meta.glob('../**/*.astro', { eager: true });
  const excludePages = new Set(['index', 'contact', 'cookies', 'privacy-policy', 'privacy', 'gdpr', 'sitemap', '404', 'about', 'terms', 'disclaimer-afiliere', 'politica-cookies', 'politica-de-confidentialitate', 'politica-confidentialitate', 'termeni-si-conditii']);
  const excludeDirs = new Set(['blog', 'masini-de-spalat', 'frigidere', 'cuptoare-aragazuri', 'aspiratoare', 'masini-spalat-vase', 'electrocasnice-mici']);

  const articles: any[] = [];
  for (const [path, mod] of Object.entries(allPages)) {
    const parts = path.replace('../', '').replace('.astro', '').split('/');
    if (parts.length > 1 && (excludeDirs.has(parts[0]) || parts[parts.length - 1].startsWith('['))) continue;
    const name = parts[parts.length - 1];
    if (excludePages.has(name)) continue;
    const frontmatter = (mod as any).frontmatter;
    if (frontmatter?.title) articles.push(frontmatter);
  }

  articles.sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime());
  return paginate(articles, { pageSize: 12 });
}

const { page } = Astro.props;
---

<Layout
  title={`Blog Electrocasnice — Oferte, Preturi si Pareri 2026${page.currentPage > 1 ? ` — Pagina ${page.currentPage}` : ''}`}
  description="Articole despre electrocasnice — pareri, preturi, comparatii si sfaturi de cumparare actualizate 2026."
  breadcrumbs={[
    { name: 'Acasa', url: '/' },
    { name: 'Blog', url: '/blog/' }
  ]}
>
  <div class="pin-container">
    <div class="category-header">
      <h1>Blog</h1>
      <p>Toate articolele noastre despre electrocasnice — pareri, preturi si comparatii actualizate.</p>
    </div>

    <div class="pin-grid">
      {page.data.map((article: any) => (
        <ArticleCard
          title={article.title}
          slug={article.slug}
          excerpt={article.excerpt}
          image={article.image}
          category={article.category}
          categorySlug={article.categorySlug}
          date={article.date}
        />
      ))}
    </div>

    {page.lastPage > 1 && (
      <div class="pagination">
        {page.url.prev && <a href={page.url.prev}>&laquo; Inapoi</a>}
        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(num => (
          num === page.currentPage
            ? <span class="current">{num}</span>
            : <a href={num === 1 ? '/blog/' : `/blog/${num}/`}>{num}</a>
        ))}
        {page.url.next && <a href={page.url.next}>Inainte &raquo;</a>}
      </div>
    )}
  </div>
</Layout>
