  image: "/images/articles/cele-mai-bune-masini-de-spalat-rufe.webp",
  category: "Masini de Spalat Rufe",
  categorySlug: "masini-de-spalat",
  date: "2026-03-07T14:19:38.749Z",
  modifiedDate: "2026-03-07T14:19:38.750Z",
