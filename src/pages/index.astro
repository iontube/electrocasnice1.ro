---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import products from '../data/electrocasnice.json';
import categories from '../data/categories.json';

const money = (n) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const total = products.length;
// group products per category, pick the 6 most-discounted (fallback cheapest) for the homepage row
const byCat = {};
for (const p of products) (byCat[p.category] ||= []).push(p);
const sections = categories
  .map((c) => ({ ...c, items: byCat[c.slug] || [] }))
  .filter((c) => c.items.length >= 4)
  .sort((a, b) => b.items.length - a.items.length)
  .map((c) => {
    const sorted = [...c.items].sort((a, b) => {
      const da = a.oldPrice ? 1 - a.price / a.oldPrice : 0;
      const db = b.oldPrice ? 1 - b.price / b.oldPrice : 0;
      return db - da || a.price - b.price;
    });
    return { ...c, count: c.items.length, picks: sorted.slice(0, 6) };
  });
// brand + magazin hubs (moved here from the removed /electrocasnice/ index so they stay interlinked)
const brandList = Object.values(products.reduce((a, p) => { if (p.brandSlug) { (a[p.brandSlug] ||= { n: p.brand, s: p.brandSlug, c: 0 }).c++; } return a; }, {})).filter((b) => b.c >= 4).sort((a, b) => b.c - a.c).slice(0, 30);
const merchSet = {}; for (const p of products) for (const o of p.offers) (merchSet[o.merchantSlug] ||= { n: o.merchantName, s: o.merchantSlug, c: 0 }).c++;
const merchList = Object.values(merchSet).filter((m) => m.c >= 4).sort((a, b) => b.c - a.c);
const mainModified = products.reduce((m, p) => (p.modified && p.modified > m ? p.modified : m), '2026-04-01');
const title = `Electrocasnice ieftine 2026 — ${total} de oferte, prețuri și comparații | Electrocasnice1.ro`;
const description = `Cele mai mici prețuri la electrocasnice în 2026: frigidere, mașini de spălat, aragaze, aspiratoare, aparate de cafea și multe altele. ${total} de produse din magazinele partenere, comparate pe preț.`;
---
<Layout title={title} description={description} modified={mainModified}>
  <SchemaMarkup modified={mainModified} />
  <Nav />
  <section class="rec-sec" style="padding-top:calc(64px + 1.4rem)">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-head__tag">Electrocasnice 2026</span>
        <h1>Electrocasnice ieftine, comparate pe preț</h1>
        <p><strong>{total}</strong> de electrocasnice din magazinele partenere, organizate pe categorii. Îți arătăm cel mai mic preț pe fiecare model.</p>
      </div>

      {sections.map((c) => (
        <div class="cat-sec">
          <div class="cat-sec__head">
            <h2>{c.label}</h2>
            <a class="cat-sec__all" href={`/${c.slug}/`}>Vezi toate cele {c.count} →</a>
          </div>
          <div class="products">
            {c.picks.map((p) => (
              <article class="card">
                {p.oldPrice && <span class="card__badge card__badge--value">-{Math.round((1 - p.price / p.oldPrice) * 100)}%</span>}
                <a class="card__img" href={`/produs/${p.slug}/`} aria-label={p.name}><img src={p.img} alt={p.name} width="200" height="200" loading="lazy" decoding="async" /></a>
                <div class="card__body">
                  <a href={`/produs/${p.slug}/`}><h3 class="card__name">{p.name}</h3></a>
                  <div class="card__specs">{Object.values(p.specs).slice(1, 4).map((v) => <span class="card__spec">{v}</span>)}</div>
                  <div class="card__price-row"><span class="card__price">{money(p.price)}</span>{p.oldPrice && <s>{money(p.oldPrice)}</s>}</div>
                  <div class="card__foot"><a href={`/produs/${p.slug}/`} class="card__cta">Vezi detalii</a></div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

      <div class="rec-links"><h2>După brand</h2><div class="rec-links__row">{brandList.map((b) => <a class="rec-pg" href={`/brand/${b.s}/`}>{b.n} <span>({b.c})</span></a>)}</div></div>
      <div class="rec-links"><h2>După magazin</h2><div class="rec-links__row">{merchList.map((m) => <a class="rec-pg" href={`/magazin/${m.s}/`}>{m.n} <span>({m.c})</span></a>)}</div></div>
    </div>
  </section>
  <Footer />
</Layout>
