};

const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Aspiratoare", url: "/aspiratoare/" },
  { name: "Cel mai bun aspirator vertical fara fir", url: "/cel-mai-bun-aspirator-vertical-fara-fir/" }
];

const faq = [
  { question: "Ce inseamna puterea de aspiratie (AW) la aspiratoarele verticale fara fir?", answer: "Puterea de aspiratie, masurata in Air Watts (AW), indica eficienta cu care aspiratorul aspira aerul si particulele. Un AW mai mare inseamna, in general, o putere de aspiratie mai mare, capabila sa curete mai eficient diverse tipuri de murdarie si pe diferite suprafete." },
  { question: "Cat tine bateria unui aspirator vertical fara fir?", answer: "Autonomia unei baterii variaza de la 20 la peste 80 de minute, in functie de model si de modul de utilizare. Modurile de putere maxima consuma bateria mai repede. Majoritatea modelelor performante ofera intre 45 si 65 de minute de autonomie in modurile standard." },
  { question: "Este necesar sa cumpar accesorii suplimentare pentru aspiratorul vertical?", answer: "Depinde de model. Multe aspiratoare vin cu un set bogat de accesorii (duze inguste, perii mici, perii pentru par de animale). Daca ai nevoi specifice, cum ar fi curatarea saltelelor sau a zonelor inalte, poate fi necesara achizitionarea unor accesorii dedicate." },
  { question: "Cat de des trebuie sa golesc recipientul de praf?", answer: "Recipientul de praf la aspiratoarele verticale are de obicei o capacitate mica (0.4L - 0.9L). Pentru o eficienta maxima, este recomandat sa il golesti dupa fiecare utilizare sau cel putin o data pe saptamana, in functie de cantitatea de praf aspirata." },
  { question: "Pot folosi un aspirator vertical fara fir pentru toata casa?", answer: "Da, multe modele sunt concepute pentru a fi utilizate ca aspirator principal. Versatilitatea lor, greutatea redusa si lipsa cablului le fac ideale pentru curatenia rapida si pentru a ajunge in locuri greu accesibile. Totusi, pentru suprafete foarte mari sau sarcini de curatenie grele, un aspirator traditional cu sac ar putea fi inca o optiune." }
];

const toc = [
  { title: "Samsung Bespoke Jet AI Complete", id: "samsung-bespoke-jet-ai-complete" },
  { title: "Dyson V15 Detect Absolute", id: "dyson-v15-detect-absolute" },
  { title: "Electrolux 800 Series (EP81B25UMB)", id: "electrolux-800-series-ep81b25umb" },
  { title: "Philips SpeedPro Max Aqua (XC8348/01)", id: "philips-speedpro-max-aqua-xc834801" },
  { title: "Bosch Unlimited Serie 8 Gen2 (BSS8224)", id: "bosch-unlimited-serie-8-gen2-bss8224" },
  { title: "Rowenta X-Force Flex 15.60 (RH99C1)", id: "rowenta-x-force-flex-1560-rh99c1" },
  { title: "Comparatie", id: "comparatie" },
  { title: "Cum alegi cel mai bun aspirator vertical fara fir?", id: "sfaturi" },
