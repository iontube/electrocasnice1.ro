const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

<Layout
  title="Cel mai bun aspirator vertical fara fir 2026 — Electrocasnice1.ro"
  description="Cel mai bun aspirator vertical fara fir in 2026 este modelul X de la Brand Y, oferind o combinatie de putere de aspiratie, autonomie si versatilitate la un pret accesibil. Daca iti doresti sa scapi de corvoada aspiratului zilnic cu un aparat usor de manevrat si fara batai de cap legate de saci sau cabluri, cautarea ta se poate incheia aici, insa alegerea finala depinde de nevoile specifice ale locuintei tale, de tipul de suprafete pe care le cureti cel mai des si de bugetul pe care esti dispus sa-l aloci."
  image="/images/articles/cel-mai-bun-aspirator-vertical-fara-fir.webp"
  type="article"
  publishedTime="2026-03-08T14:34:39.334Z"
  modifiedTime="2026-03-08T14:34:39.334Z"
