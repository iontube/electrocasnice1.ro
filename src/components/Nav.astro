---
import categories from '../data/categories.json';
const top = categories.slice(0, 6);
---
<nav class="nav">
  <div class="nav__bar">
    <a href="/" class="nav__logo" aria-label="Electrocasnice1 — Acasă"><img src="/logo.png" alt="Electrocasnice1" width="152" height="36" decoding="async" /></a>
    <div class="nav__links">
      <a href="/">Acasă</a>
      <a href="/frigidere/">Frigidere</a>
      <a href="/aragaze-cuptoare/">Aragaze</a>
      <a href="/aspiratoare/">Aspiratoare</a>
      <a href="/electrocasnice-mici/">Electrocasnice mici</a>
    </div>
    <a href="/frigidere/" class="nav__cta">Vezi ofertele</a>
    <button class="nav__burger" id="navBurger" aria-label="Meniu"><span></span></button>
  </div>
</nav>
<div class="nav__drawer" id="navDrawer">
  <div class="nav__scrim" id="navScrim"></div>
  <div class="nav__panel">
    <div class="nav__panel-head"><div class="nav__panel-title"><img src="/logo.png" alt="Electrocasnice1" width="130" height="31" decoding="async" /></div><button class="nav__panel-close" id="navClose">&times;</button></div>
    <a href="/">Acasă</a>
    {top.map((c) => <a href={`/${c.slug}/`}>{c.label}</a>)}
  </div>
</div>
